DEBUG=True
SECRET_KEY=change-me-to-a-real-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
LANGUAGE_CODE=fr
SITE_URL=http://localhost:8000

# Database (leave empty to use SQLite in dev; set for PostgreSQL in prod)
# DATABASE_URL=postgres://user:password@host:5432/prava

# Mollie Payment (test_xxx = test mode, live_xxx = production)
MOLLIE_API_KEY=test_REPLACE_WITH_YOUR_MOLLIE_TEST_KEY

# Mailjet SMTP (used in production; console backend used in DEBUG mode)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
DEFAULT_FROM_EMAIL=noreply@prava.be
ADMIN_EMAIL=admin@prava.be

# Sentry — leave empty locally, set DSN on the server
SENTRY_DSN=